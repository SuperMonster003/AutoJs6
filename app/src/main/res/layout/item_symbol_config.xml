<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="4dp">

    <org.autojs.autojs.theme.widget.ThemeColorCheckBox
        android:id="@+id/cbEnabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical" />

    <FrameLayout
        android:id="@+id/symbolEditorContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        android:paddingHorizontal="10dp">

        <TextView
            android:id="@+id/tvSymbol"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:ellipsize="middle"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/day_night_full"
            android:textSize="18sp"
            tools:text="=" />

        <LinearLayout
            android:id="@+id/symbolEditPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <EditText
                android:id="@+id/etSymbol"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:imeOptions="actionDone"
                android:inputType="textNoSuggestions"
                android:maxLines="1"
                android:textColor="@color/day_night_full"
                android:textSize="18sp"
                tools:text="=" />
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/ivAdd"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="4dp"
            android:paddingHorizontal="4dp"
            android:src="@drawable/ic_add_black_48dp"
            app:tint="@color/day_night_alpha_70" />

        <ImageView
            android:id="@+id/ivDrag"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="4dp"
            android:paddingHorizontal="4dp"
            android:src="@drawable/ic_drag_handle_black_48dp"
            app:tint="@color/day_night_alpha_70" />

        <ImageView
            android:id="@+id/ivDelete"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="4dp"
            android:paddingHorizontal="4dp"
            android:src="@drawable/ic_close_black_48dp"
            app:tint="@color/day_night_alpha_70" />
    </LinearLayout>
</LinearLayout>