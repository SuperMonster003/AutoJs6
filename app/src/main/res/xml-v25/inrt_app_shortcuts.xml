<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="id_inrt_launcher_shortcut_log"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/text_app_shortcut_log_short_label"
        android:shortcutLongLabel="@string/text_app_shortcut_log_short_label"
        android:shortcutDisabledMessage="@string/text_app_shortcut_disabled">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetClass="org.autojs.autojs.inrt.LogActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <shortcut
        android:shortcutId="id_inrt_launcher_shortcut_settings"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/text_app_shortcut_settings_short_label"
        android:shortcutLongLabel="@string/text_app_shortcut_settings_short_label"
        android:shortcutDisabledMessage="@string/text_app_shortcut_disabled">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetClass="org.autojs.autojs.inrt.SettingsActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>
</shortcuts>
